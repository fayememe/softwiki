# Database Configuration
# SQLite local file by default
DATABASE_URL=sqlite:///data/softwiki.db

# LLM API Configuration
OPENAI_API_KEY=your_openai_api_key_here
# Optional: custom base URL (useful for proxy, DeepSeek, Groq, or Gemini OpenAI compatibility)
# OPENAI_API_BASE=https://api.openai.com/v1

# Models
# Model profile configurations are mapped in configs/model_profiles.yaml
# You can override them here if needed
EXTRACTION_MODEL=gpt-4o-mini
ANALYSIS_MODEL=gpt-4o

# Shell / TUI Model (independent from Core LLM)
# The shell agent (opencode) can use a different model and API endpoint than SoftWiki Core.
# If not set, falls back to ANALYSIS_MODEL / OPENAI_API_BASE / OPENAI_API_KEY above.
# SHELL_MODEL=gemini-2.5-flash
# SHELL_API_BASE=https://generativelanguage.googleapis.com/v1beta/
# SHELL_API_KEY=your_shell_api_key_here

# Embeddings
# Can be "local" (uses basic TF-IDF/internal sentence similarity if PyTorch is not available, or local sentence-transformers)
# or "openai" (uses OpenAI API)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Shell Search (client-side, per-user — does NOT go through the SoftWiki server)
# Default: DuckDuckGo via webfetch, free, no key needed.
# For better quality, add one of the following (priority: Exa > Tavily):
# EXA_API_KEY=...        # exa.ai — 1000 free queries/month
# TAVILY_API_KEY=...     # tavily.com — 1000 free queries/month (if not used for server search)
# See docs/shell-search.md for more options.

# SoftWiki Server Web Search (BYOK - for the softwiki_web_search MCP tool)
# Used only when external agents call the softwiki MCP directly.
# Shell users should use their own BRAVE_API_KEY above instead.
# Configure one of the following providers (checked in order: Tavily > SerpAPI > Bing):

# Tavily (recommended for AI/RAG, 1000 free searches/month)
# Sign up at https://tavily.com
# TAVILY_API_KEY=tvly-...

# SerpAPI (supports Google, Bing, Baidu, etc., 100 free searches/month)
# Sign up at https://serpapi.com
# SERPAPI_KEY=...

# Bing Web Search API (Azure Cognitive Services, 1000 free searches/month)
# Set up at https://portal.azure.com
# BING_SEARCH_API_KEY=...
